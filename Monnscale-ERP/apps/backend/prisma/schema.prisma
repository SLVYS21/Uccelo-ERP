// =====================================================================
// Moonscale ERP — Prisma schema for MongoDB
// Port of the Laravel migrations in apps/backend/../uccello-crm-main.
// Conventions:
//  - All `_id` fields use Mongo ObjectId (auto-generated).
//  - `teamId` on every business document is the multi-tenant key.
//  - `deletedAt` is soft-delete (handled via Prisma middleware in code).
//  - `customFields` is a free-form JSON map: validated at the
//    application layer against CustomFieldDefinition documents.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// AUTH / TENANCY
// ----------------------------------------------------------------------

model User {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  email                  String   @unique
  emailVerifiedAt        DateTime?
  password               String
  twoFactorSecret        String?
  twoFactorRecoveryCodes String?
  twoFactorConfirmedAt   DateTime?
  rememberToken          String?
  locale                 String?
  currentTeamId          String?  @db.ObjectId
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  currentTeam      Team?              @relation("UserCurrentTeam", fields: [currentTeamId], references: [id])
  memberships      Membership[]
  invitationsSent  TeamInvitation[]   @relation("InvitedBy")
  ownedDeals       Deal[]             @relation("DealOwner")
  ownedCompanies   Company[]          @relation("CompanyOwner")
  ownedContacts    Contact[]          @relation("ContactOwner")
  assignedTasks    Task[]             @relation("TaskAssignee")
  activities       Activity[]         @relation("ActivityUser")
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]

  @@map("users")
}

model Team {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  slug       String   @unique
  isPersonal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  memberships      Membership[]
  invitations      TeamInvitation[]
  usersCurrentlyOn User[]                   @relation("UserCurrentTeam")
  pipelines        Pipeline[]
  companies        Company[]
  contacts         Contact[]
  deals            Deal[]
  tasks            Task[]
  activities       Activity[]
  customFields     CustomFieldDefinition[]
  picklistOptions  PicklistOption[]

  @@map("teams")
}

model Membership {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String   @db.ObjectId
  userId    String   @db.ObjectId
  role      String   // TeamRole enum (owner|admin|member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvitation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  code       String   @unique
  teamId     String   @db.ObjectId
  email      String
  role       String
  invitedById String  @db.ObjectId
  expiresAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy  User @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("team_invitations")
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ----------------------------------------------------------------------
// PIPELINES + STAGES
// ----------------------------------------------------------------------

model Pipeline {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String   @db.ObjectId
  name      String
  isDefault Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  team   Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  stages PipelineStage[]
  deals  Deal[]

  @@index([teamId])
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  pipelineId  String   @db.ObjectId
  name        String
  key         String
  color       String?
  position    Int      @default(0)
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, key])
  @@index([pipelineId, position])
  @@map("pipeline_stages")
}

// ----------------------------------------------------------------------
// CRM CORE: companies / contacts / deals / tasks / activities
// ----------------------------------------------------------------------

model Company {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId       String   @db.ObjectId
  name         String
  domain       String?
  industry     String?
  phone        String?
  website      String?
  address      String?
  city         String?
  postalCode   String?
  country      String?
  ownerId      String?  @db.ObjectId
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  team     Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner    User?     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contacts Contact[]
  deals    Deal[]

  @@index([teamId, name])
  @@map("companies")
}

model Contact {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId       String   @db.ObjectId
  firstName    String
  lastName     String
  email        String?
  phone        String?
  jobTitle     String?
  companyId    String?  @db.ObjectId
  ownerId      String?  @db.ObjectId
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  team    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner   User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deals   Deal[]

  @@index([teamId, lastName, firstName])
  @@index([companyId])
  @@map("contacts")
}

model Deal {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId             String   @db.ObjectId
  pipelineId         String   @db.ObjectId
  pipelineStageId    String   @db.ObjectId
  companyId          String?  @db.ObjectId
  contactId          String?  @db.ObjectId
  name               String
  amount             Float?
  currency           String   @default("XOF")
  status             String   @default("open") // DealStatus enum
  expectedCloseDate  DateTime?
  closedAt           DateTime?
  position           Int      @default(0)
  ownerId            String?  @db.ObjectId
  customFields       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  team     Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage    PipelineStage @relation(fields: [pipelineStageId], references: [id], onDelete: Cascade)
  company  Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner    User?         @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([teamId, pipelineStageId, position])
  @@index([companyId])
  @@index([contactId])
  @@map("deals")
}

model Task {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId        String   @db.ObjectId
  title         String
  description   String?
  dueAt         DateTime?
  priority      String   @default("normal") // TaskPriority
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  assigneeId    String?  @db.ObjectId
  // Polymorphic relation — mirrors Laravel `taskable_type` + `taskable_id`.
  taskableType  String?  // CrmEntity value
  taskableId    String?  @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team     Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([teamId, isCompleted, dueAt])
  @@index([taskableType, taskableId])
  @@map("tasks")
}

model Activity {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId          String   @db.ObjectId
  type            String
  subject         String?
  body            String?
  occurredAt      DateTime
  // Polymorphic — mirrors Laravel `subjectable_type` + `subjectable_id`.
  subjectableType String
  subjectableId   String   @db.ObjectId
  userId          String?  @db.ObjectId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation("ActivityUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([teamId, occurredAt])
  @@index([subjectableType, subjectableId])
  @@map("activities")
}

// ----------------------------------------------------------------------
// CUSTOM FIELDS + PICKLISTS
// ----------------------------------------------------------------------

model CustomFieldDefinition {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId       String   @db.ObjectId
  entityType   String   // CrmEntity value
  key          String
  label        String
  type         String   // CustomFieldType
  options      Json?
  isRequired   Boolean  @default(false)
  isFilterable Boolean  @default(false)
  position     Int      @default(0)
  helpText     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Mongo can't express the partial unique "WHERE deleted_at IS NULL" so we
  // enforce uniqueness in the application layer (CreateCustomField use case).
  @@index([teamId, entityType, position])
  @@map("custom_field_definitions")
}

model PicklistOption {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String   @db.ObjectId
  picklist  String   // Picklist enum value
  value     String
  label     String
  color     String?
  position  Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, picklist, position])
  @@map("picklist_options")
}
