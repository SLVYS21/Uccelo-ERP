# Copy to .env.staging on the VPS and fill in real values.

# Your registered domain (LWS) — the stack serves staging.${DOMAIN}
DOMAIN=tondomaine.com

# Name of the Docker network where Traefik lives (default: web).
# Find with: docker network ls   then check Traefik container's network.
TRAEFIK_NETWORK=web

# Name of the certResolver block declared in your traefik.yml (e.g. letsencrypt).
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Database (MongoDB Atlas) ---
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/monnscale?appName=Cluster0

# --- JWT ---
JWT_ACCESS_SECRET=change-me-min-32-chars-random
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-different-min-32-chars-random
JWT_REFRESH_TTL=2592000

# --- AI Assistant (optional) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
