# =====================================================================
# Moonscale ERP — environment variables
# =====================================================================

# Application
NODE_ENV=development
APP_NAME=Moonscale ERP
APP_URL=http://localhost:5173

# Backend
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# MongoDB (replica set required for Prisma transactions)
DATABASE_URL=mongodb+srv://sylvanusboni2005_db_user:sv1E7RHrY9hKEsk3@cluster0.791eu76.mongodb.net/?appName=Cluster0
# sv1E7RHrY9hKEsk3 # sylvanusboni2005_db_user

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_SECRET=replace-me-too-with-another-string
JWT_REFRESH_TTL=2592000       # seconds (30 days)

# Mail (SMTP / log driver)
MAIL_DRIVER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Moonscale ERP <hello@Moonscale.com>"

# AI assistant — Anthropic (Claude)
